# ── AI — Groq (free at console.groq.com, no credit card needed) ──
GROQ_API_KEY=gsk_your_groq_key_here

# Groq model to use — pick one:
# llama-3.1-8b-instant        → fastest (~800 t/s), good for chat
# llama-3.1-70b-versatile     → best balance (RECOMMENDED for demo)
# llama-3.2-90b-vision-preview → most capable
GROQ_MODEL=groq/llama3-70b-8192

# ── Database ─────────────────────────────────────────────────────
# SQLite (easiest for local dev — zero setup)
DATABASE_URL=sqlite+aiosqlite:///./finanalyzer.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/finanalyzer

# ── Redis (optional — needed for Celery task queue) ───────────────
REDIS_URL=redis://localhost:6379

# ── Market Data (optional — Yahoo Finance works without a key) ───
# ALPHA_VANTAGE_KEY=your-key-here
# POLYGON_API_KEY=your-key-here

# ── Security ─────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ── Email alerts (optional) ───────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
